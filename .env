SERVICE_NAME=ai-devops-incident-response-agent
ENVIRONMENT=local
LOG_LEVEL=INFO

# Gemini is required for production RCA/action planning.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_OFFLINE_MODE=false
GEMINI_TIMEOUT_SECONDS=30

# Safety defaults: validate actions, but do not mutate the cluster until DRY_RUN=false.
DRY_RUN=true
AUTO_ACTION_ENABLED=true
ACTION_CONFIDENCE_THRESHOLD=0.72
ALLOWED_NAMESPACES=default,prod,staging
K8S_NAMESPACE=default
K8S_DEFAULT_DEPLOYMENT=checkout-api
MIN_REPLICAS=1
MAX_REPLICAS=10

ANOMALY_SCORE_THRESHOLD=0.68
ANOMALY_MIN_HISTORY=20
ANOMALY_HISTORY_LIMIT=500
BASELINE_PATH=data/baseline_state.json

MEMORY_BACKEND=chroma
MEMORY_PATH=data/incidents_chroma
MEMORY_COLLECTION=sre_incidents
MEMORY_SEARCH_LIMIT=5

API_HOST=0.0.0.0
API_PORT=8000
PROMETHEUS_METRICS_ENABLED=true
